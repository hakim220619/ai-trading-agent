# ===========================================================
# AI Trading Agent - Environment Configuration
# Copy this file to ".env" and fill in your real credentials.
# NEVER commit your real .env file.
# ===========================================================

# --- MetaTrader 5 credentials ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Optional: absolute path to terminal64.exe (leave empty for auto-detect)
MT5_PATH=

# --- Instrument ---
SYMBOL=XAUUSD
TIMEFRAMES=M1,M5,M15,H1
CANDLES=500

# --- Risk / lot ---
LOT_DEFAULT=0.01
RISK_PERCENT=1
RISK_REWARD=2.0
MAX_SPREAD_POINTS=300
MAX_OPEN_POSITIONS=2

# --- Behaviour / safety ---
# IMPORTANT: keep this false until you have tested everything.
TRADING_ENABLED=false
AUTO_START=false
TARGET_PROFIT_MONEY=5
TRAILING_STOP=true
TRAILING_START_POINTS=200
TRAILING_STEP_POINTS=100
MAGIC_NUMBER=220619

# --- ML ---
ML_PROB_THRESHOLD=0.70
MODEL_PATH=app/ml/models/xgboost_model.json
MTF_CONFIRMATION=true
MTF_MIN_AGREEMENT=0.50

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
